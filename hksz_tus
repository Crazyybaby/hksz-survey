      <div className="td-header">
        <h1>时间利用日记</h1><div className="subtitle">以 30 分钟为单位，记录您最近一个工作日的活动安排</div>
        <div className="progress-wrap"><div className="progress-bar"><div className="progress-fill" style={{width:pct+"%"}}/></div>
        <div className="progress-text"><span>已填写 {filled}/48</span><span>{pct}%</span></div></div>
      </div>
      <div className="tab-bar">
        <button className={"tab-btn"+(page==="diary"?" active":"")} onClick={()=>setPage("diary")}>时间轴</button>
        <button className={"tab-btn"+(page==="review"?" active":"")} onClick={()=>setPage("review")}>总览 · 提交</button>
      </div>

      {page==="diary"&&<div className="timeline">{Array.from({length:48},(_,i)=>{
        const sec=SECTIONS.find(s=>s.slot===i),s=slots[i],act=s?getA(s.primary):null,venue=s?getVenue(s.venue):null;
        return(<div key={i}>{sec&&<div className="time-divider">{sec.label}</div>}
          <div className={"slot-row"+(inR(i)?" selected":"")} onClick={()=>click(i)}>
            <div className="slot-time">{slotRange(i)}</div>
            <div className="slot-content">{s?(<div className="slot-filled">
              <div className="slot-color" style={{background:act?.color||"#94a3b8"}}/>
              <div className="slot-info"><div className="slot-activity">{act?.icon} {act?.label}</div><div className="slot-venue">{venue?.label||s.venue}{formatLocationShort(s)?" · "+formatLocationShort(s):""}</div></div>
              <div className="slot-mood">{MOODS.find(m=>m.val===s.mood)?.emoji}</div>
            </div>):<div className="slot-empty">点击填写</div>}</div>
          </div></div>);
      })}</div>}

      {page==="review"&&<div className="review">
        {merged.length===0?<div className="empty-review"><div className="icon">尚未填写</div><p>目前还没有记录任何时段。</p></div>:(
        <>{merged.map((b,i)=>{const act=getA(b.data.primary),sec=b.data.secondary!=="none"?getA(b.data.secondary):null,venue=getVenue(b.data.venue);
          return(<div key={i} className="review-block"><div className="review-time">{slotLabel(b.from)}–{slotLabel(b.to+1)}</div>
            <div className="review-detail"><div className="act-name">{act?.icon} {act?.label}</div>
            <div className="meta">{sec&&<>副：{sec.icon} {sec.label} · </>}{venue?.label||b.data.venue}{formatLocationFull(b.data)?" · "+formatLocationFull(b.data):""} · {MOODS.find(m=>m.val===b.data.mood)?.emoji}</div></div></div>);
        })}
        {filled<48&&<div className="warning-box">⚠ 尚有 {48-filled} 个时段未填写。建议填写完整后再提交。</div>}
        <div className="submit-section">
          <button className="start-btn" disabled={submitting||filled===0} onClick={submit} style={{marginTop:8}}>
            {submitting?<><span className="spinner"></span>提交中…</>:"确认提交"}
          </button>
          <p style={{fontSize:11,color:"var(--text3)",marginTop:12,textAlign:"center",lineHeight:1.5}}>数据将直接发送至研究团队 · 编号：{rid}</p>
        </div></>)}
      </div>}

      {selStart!==null&&!showModal&&<div className="batch-bar">
        <div className="info">已选 {Math.abs((selEnd??selStart)-selStart)+1} 个时段
          <small>{slotLabel(Math.min(selStart,selEnd??selStart))}–{slotLabel(Math.max(selStart,selEnd??selStart)+1)}</small></div>
        <div><button className="btn-cancel" onClick={cancel}>取消</button><button className="btn-fill" onClick={()=>openEd(selStart,selEnd??selStart)}>填写 →</button></div>
      </div>}

      {showModal&&<div className="modal-overlay" onClick={e=>{if(e.target===e.currentTarget){setShowModal(false);cancel();}}}>
        <div className="modal-sheet"><div className="handle"/>
          <h2>填写活动信息</h2>
          <div className="time-range">🕐 {slotLabel(Math.min(selStart,selEnd))} – {slotLabel(Math.max(selStart,selEnd)+1)}（{Math.abs(selEnd-selStart)+1} 个时段）</div>
          <label className="field-label">主要活动 *</label>
          <div className="field-hint">单击直接选择；如果想看定义和示例，可点每个活动右侧的 `i`。</div>
          <div className="act-grid">{ACTIVITIES.map(a=><div key={a.id} className={"act-chip"+(edP===a.id?" active":"")} onClick={()=>pickP(a.id)}><span className="emoji">{a.icon}</span><span className="label">{a.label}</span><button type="button" className="help-btn" aria-label={"查看"+a.label+"说明"} onClick={e=>openHelp(a,e)}>i</button></div>)}</div>
          <label className="field-label">次要活动</label>
          <div className="act-grid">
            <div className={"act-chip"+(edS==="none"?" active":"")} onClick={()=>setEdS("none")}><span className="emoji">✖️</span><span>无</span></div>
            {ACTIVITIES.filter(a=>a.id!==edP&&a.id!=="sleep").map(a=><div key={a.id} className={"act-chip"+(edS===a.id?" active":"")} onClick={()=>setEdS(a.id)}><span className="emoji">{a.icon}</span><span className="label">{a.label}</span><button type="button" className="help-btn" aria-label={"查看"+a.label+"说明"} onClick={e=>openHelp(a,e)}>i</button></div>)}
          </div>
          <label className="field-label">活动地点位置 *</label>
          <div className="loc-toggle">
            <button className={!edMov?"active":""} onClick={()=>{
              setEdMov(false);
              if(isMovingVenue(edV)) setEdV("");
            }}>特定地点</button>
            <button className={edMov?"active":""} onClick={()=>{
              setEdMov(true);
              setEdLocCity("");
              setEdLocLine("");
              setEdLocStation("");
              if(!isMovingVenue(edV)) setEdV("");
            }}>移动中</button>
          </div>
          {!edMov&&<>
            <div className="field-hint">先选择香港或深圳，再选择对应地铁线路和最近地铁站。</div>
            <div className="city-row">{metroCities.map(city=><button key={city} className={"city-chip"+(edLocCity===city?" active":"")} onClick={()=>{setEdLocCity(city);setEdLocLine("");setEdLocStation("");}}>{city}</button>)}</div>
            <div className="select-panel">
              <label className="select-label">地铁线路</label>
              <select className="select-input" value={edLocLine} disabled={!edLocCity} onChange={e=>{setEdLocLine(e.target.value);setEdLocStation("");}}>
                <option value="">{edLocCity?"请选择地铁线路":"请先选择城市"}</option>
                {lineOptions.map(line=><option key={line} value={line}>{line}</option>)}
              </select>
            </div>
            <div className="select-panel">
              <label className="select-label">最近地铁站</label>
              <select className="select-input" value={edLocStation} disabled={!edLocLine} onChange={e=>setEdLocStation(e.target.value)}>
                <option value="">{edLocLine?"请选择最近地铁站":"请先选择地铁线路"}</option>
                {stationOptions.map(station=><option key={station} value={station}>{station}</option>)}
              </select>
            </div>
          </>}
          <label className="field-label">场所类型 *</label>
          {(edMov?MOVING_VENUE_GROUPS:FIXED_VENUE_GROUPS).map(group=><div key={group.title} className="venue-group"><div className="venue-group-title">{group.title}</div><div className="venue-chips">{group.options.map(v=><div key={v.id} className={"venue-chip"+(edV===v.id?" active":"")} onClick={()=>setEdV(v.id)}><span>{v.label}</span></div>)}</div></div>)}
          <label className="field-label">心情 *</label>
          <div className="mood-row">{MOODS.map(m=><div key={m.val} className={"mood-btn"+(edM===m.val?" active":"")} onClick={()=>setEdM(m.val)}>{m.emoji}<small>{m.val}</small></div>)}</div>
          <div className="modal-actions">
            {slots[Math.min(selStart,selEnd)]&&<button className="btn-danger" onClick={clear}>清除</button>}
            <button className="btn-secondary" onClick={()=>{setShowModal(false);cancel();}}>取消</button>
            <button className="btn-primary" disabled={!edP||!edV||!validLocation} onClick={save}>确认保存</button>
          </div>
        </div>
      </div>}
      {helpAct&&<div className="help-overlay" onClick={()=>setHelpAct(null)}>
        <div className="help-card" onClick={e=>e.stopPropagation()}>
          <div className="help-card-head">
            <div>
              <h3>{helpAct.icon} {helpAct.label}</h3>
            </div>
            <button type="button" className="help-close" aria-label="关闭说明" onClick={()=>setHelpAct(null)}>×</button>
          </div>
          <p>{helpAct.definition}</p>
          <div className="help-section">
            <strong>常见示例</strong>
            <ul className="help-list">
              {helpAct.examples.map(example=><li key={example}>{example}</li>)}
            </ul>
          </div>
        </div>
      </div>}
    </div>
  );
}
ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
